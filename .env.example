# Twilio credentials — from the Twilio Console (console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# WhatsApp Sandbox sender number — Console > Messaging > Try it out > Send a WhatsApp message
# Include the "whatsapp:" prefix and country code, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# The join keyword shown on that same Sandbox page, e.g. "join example-word"
# Shown on the Connect screen so the evaluator knows what to text before connecting.
TWILIO_SANDBOX_JOIN_CODE=join example-word

# Groq API key — console.groq.com (genuine free developer tier, no card required).
# Uses the OpenAI-compatible endpoint at api.groq.com/openai/v1.
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
